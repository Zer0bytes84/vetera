@import "tailwindcss";
@import "tw-animate-css";
@import "shadcn/tailwind.css";
@import "@fontsource-variable/inter";
@import "@fontsource-variable/geist";

/* BlockNote shadcn integration — required for Tailwind to generate BlockNote's utility classes */
@source "../node_modules/@blocknote/shadcn";

@custom-variant dark (&:is(.dark *));

@theme inline {
  --font-heading: var(--font-sans);
  --font-sans: 'Geist Variable', sans-serif;
  --color-sidebar-ring: var(--sidebar-ring);
  --color-sidebar-border: var(--sidebar-border);
  --color-sidebar-accent-foreground: var(--sidebar-accent-foreground);
  --color-sidebar-accent: var(--sidebar-accent);
  --color-sidebar-primary-foreground: var(--sidebar-primary-foreground);
  --color-sidebar-primary: var(--sidebar-primary);
  --color-sidebar-foreground: var(--sidebar-foreground);
  --color-sidebar: var(--sidebar);
  --color-chart-5: var(--chart-5);
  --color-chart-4: var(--chart-4);
  --color-chart-3: var(--chart-3);
  --color-chart-2: var(--chart-2);
  --color-chart-1: var(--chart-1);
  --color-ring: var(--ring);
  --color-input: var(--input);
  --color-border: var(--border);
  --color-destructive: var(--destructive);
  --color-accent-foreground: var(--accent-foreground);
  --color-accent: var(--accent);
  --color-muted-foreground: var(--muted-foreground);
  --color-muted: var(--muted);
  --color-secondary-foreground: var(--secondary-foreground);
  --color-secondary: var(--secondary);
  --color-primary-foreground: var(--primary-foreground);
  --color-primary: var(--primary);
  --color-popover-foreground: var(--popover-foreground);
  --color-popover: var(--popover);
  --color-card-foreground: var(--card-foreground);
  --color-card: var(--card);
  --color-foreground: var(--foreground);
  --color-background: var(--background);
  --radius-sm: calc(var(--radius) * 0.6);
  --radius-md: calc(var(--radius) * 0.8);
  --radius-lg: var(--radius);
  --radius-xl: calc(var(--radius) * 1.4);
  --radius-2xl: calc(var(--radius) * 1.8);
  --radius-3xl: calc(var(--radius) * 2.2);
  --radius-4xl: calc(var(--radius) * 2.6);
}


/* ─── Core Theme ─── */
:root {
  --background: oklch(0.97 0.018 240);
  --foreground: oklch(0.18 0.03 244);
  --card: oklch(0.998 0.006 236);
  --card-foreground: oklch(0.18 0.03 244);
  --popover: oklch(0.998 0.006 236);
  --popover-foreground: oklch(0.18 0.03 244);
  --primary: oklch(0.55 0.2 260);       /* Electric Blue #4f46e5 */
  --primary-foreground: oklch(0.99 0 0);
  --secondary: oklch(0.94 0.04 252);
  --secondary-foreground: oklch(0.26 0.055 254);
  --muted: oklch(0.95 0.018 240);
  --muted-foreground: oklch(0.48 0.035 248);
  --accent: oklch(0.5 0.12 260);        /* Muted Blue */
  --accent-foreground: oklch(0.99 0 0);
  --destructive: oklch(0.577 0.245 27.325);
  --border: oklch(0.86 0.03 246);
  --input: oklch(0.87 0.026 246);
  --ring: oklch(0.64 0.16 258);
  --chart-1: oklch(0.57 0.2 260);
  --chart-2: oklch(0.66 0.17 176);
  --chart-3: oklch(0.72 0.17 72);
  --chart-4: oklch(0.6 0.12 260);
  --chart-5: oklch(0.55 0.08 240);
  --radius: 0.625rem;
  --sidebar: oklch(0.98 0.018 242);
  --sidebar-foreground: oklch(0.24 0.035 246);
  --sidebar-primary: oklch(0.55 0.2 260);
  --sidebar-primary-foreground: oklch(0.99 0 0);
  --sidebar-accent: oklch(0.93 0.052 252);
  --sidebar-accent-foreground: oklch(0.25 0.07 258);
  --sidebar-border: oklch(0.84 0.034 246);
  --sidebar-ring: oklch(0.64 0.16 258);
  --bg-app: oklch(0.97 0.018 240);
  --bg-panel: oklch(0.998 0.006 236);
  --text-primary: oklch(0.18 0.03 244);
  --text-secondary: oklch(0.4 0.045 248);
  --text-muted: oklch(0.48 0.035 248);
  --border-color: oklch(0.86 0.03 246);
  --color-surface-soft: oklch(0.95 0.024 242);
  --color-surface-soft-2: oklch(0.92 0.04 248);
  --color-chart-blue: oklch(0.57 0.2 260);
  --color-chart-red: oklch(0.58 0.22 24);
  --surface-100: oklch(0.985 0.018 236);
  --surface-200: oklch(0.95 0.024 242);
  --surface-300: oklch(0.998 0.006 236);
  --interactive-blue: oklch(0.55 0.2 260);
  --interactive-hover: oklch(0.55 0.2 260 / 0.1);
  --brand-primary: oklch(0.55 0.2 260);
  --brand-secondary: oklch(0.66 0.17 176);
  --sidebar-bg: oklch(0.98 0.018 242);
  --sidebar-text: oklch(0.4 0.045 248);
  --sidebar-text-active: oklch(0.25 0.07 258);
  --sidebar-hover-bg: oklch(0.94 0.04 252);
  --sidebar-active-bg: oklch(0.91 0.07 258);
  --success: #10b981;                    /* Emerald Green */
  --danger: oklch(0.58 0.22 24);
  --shadow-soft: 0 1px 2px rgba(10, 10, 10, 0.04);
  --shadow-card: 0 1px 2px rgba(10, 10, 10, 0.05), 0 18px 36px -32px rgba(10, 10, 10, 0.22);
  --shadow-lift: 0 20px 48px -34px rgba(10, 10, 10, 0.24);
  --retention-empty: oklch(0.97 0.02 180);
  --retention-min: oklch(0.92 0.04 180);
  --retention-low: oklch(0.85 0.08 180);
  --retention-mid: oklch(0.75 0.12 180);
  --retention-high: oklch(0.18 0.03 244);
  --task-pending: oklch(0.94 0.01 220);
  --task-cell-empty: oklch(0.97 0.005 220);
  --task-full: oklch(0.65 0.18 150);
  --task-full-glow: rgba(16, 185, 129, 0.4);
  --task-mid: oklch(0.75 0.15 45);
  --task-mid-glow: rgba(245, 158, 11, 0.35);
  --task-low: oklch(0.58 0.22 24);
  --task-low-glow: rgba(239, 68, 68, 0.35);
  --prospeo-bg: oklch(0.975 0.006 240);
  --prospeo-shell: oklch(0.996 0.003 240 / 0.96);
  --prospeo-card: oklch(0.99 0.004 240);
  --prospeo-card-soft: oklch(0.955 0.006 240);
  --prospeo-border: oklch(0.86 0.012 240);
  --prospeo-border-strong: oklch(0.76 0.018 240);
  --prospeo-text: oklch(0.2 0.012 240);
  --prospeo-muted: oklch(0.52 0.012 240);
  --prospeo-faint: oklch(0.64 0.01 240);
  --prospeo-grid: oklch(0.84 0.012 240 / 0.7);
  --prospeo-active: oklch(0.7 0.18 55);
  --prospeo-active-2: oklch(0.6 0.18 38);
  --prospeo-shadow: 0 18px 48px -42px oklch(0.18 0.025 240 / 0.28);
  --dashboard-ink: oklch(0.18 0.018 238);
  --dashboard-surface: oklch(0.995 0.004 228);
  --dashboard-panel: oklch(0.985 0.008 228 / 0.86);
  --dashboard-border-soft: oklch(0.89 0.012 232 / 0.9);
  --dashboard-border-accent: oklch(0.72 0.08 228 / 0.24);
  --dashboard-aura-blue: oklch(0.62 0.12 246 / 0.055);
  --dashboard-aura-mint: oklch(0.78 0.1 164 / 0.055);
}

.dark {
  --background: oklch(0.12 0.03 250);     /* Midnight Blue */
  --foreground: oklch(0.96 0.01 240);
  --card: oklch(0.16 0.02 248);
  --card-foreground: oklch(0.96 0.01 240);
  --popover: oklch(0.16 0.02 248);
  --popover-foreground: oklch(0.96 0.01 240);
  --primary: oklch(0.65 0.18 260);        /* Brighter Electric Blue for dark */
  --primary-foreground: oklch(0.12 0.03 250);
  --secondary: oklch(0.22 0.04 250);
  --secondary-foreground: oklch(0.96 0.01 240);
  --muted: oklch(0.2 0.03 248);
  --muted-foreground: oklch(0.6 0.03 248);
  --accent: oklch(0.6 0.12 260);          /* Muted Blue for dark */
  --accent-foreground: oklch(0.96 0.01 240);
  --destructive: oklch(0.704 0.191 22.216);
  --border: oklch(0.28 0.04 250);
  --input: oklch(0.28 0.04 250);
  --ring: oklch(0.52 0.14 258);
  --chart-1: oklch(0.76 0.13 246);
  --chart-2: oklch(0.78 0.13 166);
  --chart-3: oklch(0.79 0.14 64);
  --chart-4: oklch(0.72 0.1 260);
  --chart-5: oklch(0.68 0.06 240);
  --sidebar: oklch(0.14 0.02 248);
  --sidebar-foreground: oklch(0.96 0.01 240);
  --sidebar-primary: oklch(0.65 0.18 260);
  --sidebar-primary-foreground: oklch(0.12 0.03 250);
  --sidebar-accent: oklch(0.22 0.04 250);
  --sidebar-accent-foreground: oklch(0.96 0.01 240);
  --sidebar-border: oklch(0.28 0.04 250);
  --sidebar-ring: oklch(0.52 0.14 258);
  --bg-app: oklch(0.12 0.03 250);
  --bg-panel: oklch(0.16 0.02 248);
  --text-primary: oklch(0.96 0.01 240);
  --text-secondary: oklch(0.6 0.03 248);
  --text-muted: oklch(0.48 0.03 248);
  --border-color: oklch(0.28 0.04 250);
  --color-surface-soft: oklch(0.18 0.025 248);
  --color-surface-soft-2: oklch(0.22 0.03 248);
  --surface-100: oklch(0.14 0.02 248);
  --surface-200: oklch(0.18 0.025 248);
  --surface-300: oklch(0.22 0.03 248);
  --interactive-blue: oklch(0.65 0.18 260);
  --interactive-hover: rgba(255, 255, 255, 0.08);
  --brand-primary: oklch(0.65 0.18 260);
  --brand-secondary: oklch(0.78 0.13 166);
  --sidebar-bg: oklch(0.14 0.02 248);
  --sidebar-text: oklch(0.6 0.03 248);
  --sidebar-text-active: oklch(0.96 0.01 240);
  --sidebar-hover-bg: oklch(0.18 0.025 248);
  --sidebar-active-bg: oklch(0.22 0.03 248);
  --success: #34d399;
  --shadow-soft: 0 1px 2px rgba(0, 0, 0, 0.25);
  --shadow-card: 0 1px 0 rgba(255, 255, 255, 0.04) inset, 0 20px 50px -38px rgba(0, 0, 0, 0.9);
  --shadow-lift: 0 1px 0 rgba(255, 255, 255, 0.06) inset, 0 24px 64px -36px rgba(0, 0, 0, 0.95);
  --retention-empty: rgba(0, 0, 0, 0.08);
  --retention-min: rgba(0, 0, 0, 0.15);
  --retention-low: rgba(0, 0, 0, 0.25);
  --retention-mid: rgba(0, 0, 0, 0.35);
  --retention-high: oklch(0.96 0.01 240);
  --task-pending: rgba(255, 255, 255, 0.05);
  --task-cell-empty: rgba(255, 255, 255, 0.03);
  --task-full: #34d399;
  --task-full-glow: rgba(52, 211, 153, 0.35);
  --task-mid: rgba(251, 191, 36, 0.7);
  --task-mid-glow: rgba(251, 191, 36, 0.3);
  --task-low: rgba(248, 113, 113, 0.7);
  --task-low-glow: rgba(248, 113, 113, 0.3);
  --prospeo-bg: oklch(0.145 0.006 240);
  --prospeo-shell: oklch(0.16 0.006 240 / 0.98);
  --prospeo-card: oklch(0.19 0.006 240);
  --prospeo-card-soft: oklch(0.225 0.006 240);
  --prospeo-border: oklch(0.31 0.008 240);
  --prospeo-border-strong: oklch(0.4 0.012 240);
  --prospeo-text: oklch(0.96 0.004 240);
  --prospeo-muted: oklch(0.68 0.006 240);
  --prospeo-faint: oklch(0.52 0.006 240);
  --prospeo-grid: oklch(0.36 0.008 240 / 0.58);
  --prospeo-active: oklch(0.74 0.17 58);
  --prospeo-active-2: oklch(0.64 0.18 38);
  --prospeo-shadow: inset 0 1px 0 oklch(1 0 0 / 0.035);
  --dashboard-ink: oklch(0.96 0.01 235);
  --dashboard-surface: oklch(0.145 0.02 236);
  --dashboard-panel: oklch(0.17 0.018 236 / 0.94);
  --dashboard-border-soft: oklch(0.3 0.024 238 / 0.9);
  --dashboard-border-accent: oklch(0.68 0.1 246 / 0.26);
  --dashboard-aura-blue: oklch(0.62 0.12 246 / 0.08);
  --dashboard-aura-mint: oklch(0.74 0.1 164 / 0.055);
}


@layer base {
  * {
    @apply border-border outline-ring/50;
  }
  .bn-shadcn * {
    @apply border-border outline-ring/50;
  }
  body {
    @apply bg-background text-foreground;
  }
  html {
    @apply font-sans;
  }
  body {
    min-height: 100vh;
    padding-top: env(titlebar-area-height, 0px);
    font-family: var(--font-sans);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    background-color: var(--bg-app);
    text-rendering: optimizeLegibility;
  }
  #root {
    min-height: 100vh;
    overflow: hidden;
    border-radius: 14px;
    box-shadow:
      0 0 0 0.5px rgba(0, 0, 0, 0.12),
      0 18px 48px -22px rgba(0, 0, 0, 0.28);
    isolation: isolate;
  }
}

@keyframes glow-pulse {
  0%,
  100% {
    box-shadow: 0 0 6px 1px currentColor;
  }

  50% {
    box-shadow: 0 0 12px 3px currentColor;
  }
}

.glass-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow:
    var(--shadow-card),
    inset 0 1px 0 0 rgba(255, 255, 255, 0.06);
  -webkit-backdrop-filter: blur(40px) saturate(1.4);
  backdrop-filter: blur(40px) saturate(1.4);
  transition:
    box-shadow 0.4s ease,
    transform 0.4s ease;
}

.glass-card:hover {
  box-shadow:
    var(--shadow-lift),
    inset 0 1px 0 0 rgba(255, 255, 255, 0.1);
  transform: translateY(-2px);
}

.glow-ring {
  animation: glow-pulse 2.5s ease-in-out infinite;
}

.raycast-header {
  background:
    linear-gradient(180deg, oklch(1 0.008 236 / 0.88), oklch(0.97 0.02 246 / 0.78)),
    var(--card);
  border-color: var(--sidebar-border);
  box-shadow:
    0 1px 0 oklch(1 0 0 / 0.64) inset,
    0 12px 30px -26px oklch(0.4 0.16 258 / 0.42);
  -webkit-backdrop-filter: blur(22px) saturate(1.2);
  backdrop-filter: blur(22px) saturate(1.2);
}

.dark .raycast-header {
  background:
    linear-gradient(180deg, oklch(0.18 0.016 246 / 0.82), oklch(0.12 0.012 246 / 0.78)),
    var(--card);
  border-color: var(--sidebar-border);
}

.raycast-header-scrolled {
  background: oklch(0.985 0.004 240 / 0.58);
  border-color: oklch(0.84 0.012 240 / 0.72);
  box-shadow:
    0 1px 0 oklch(1 0 0 / 0.74) inset,
    0 14px 32px -30px oklch(0.2 0.02 240 / 0.34);
  -webkit-backdrop-filter: blur(26px) saturate(1.28);
  backdrop-filter: blur(26px) saturate(1.28);
}

.dark .raycast-header-scrolled {
  background: oklch(0.135 0.004 240 / 0.58);
  border-color: oklch(0.34 0.01 240 / 0.76);
  box-shadow:
    0 1px 0 oklch(1 0 0 / 0.07) inset,
    0 18px 42px -32px oklch(0 0 0 / 0.74);
}

.raycast-header-control,
.raycast-header-search {
  background: oklch(0.99 0.014 238 / 0.76) !important;
  border: 1px solid oklch(0.82 0.04 250 / 0.82) !important;
  box-shadow:
    0 1px 0 oklch(1 0 0 / 0.78) inset,
    0 10px 22px -20px oklch(0.4 0.14 258 / 0.38) !important;
}

.raycast-header-control:hover,
.raycast-header-search:hover {
  background: oklch(0.94 0.052 252 / 0.84) !important;
  border-color: oklch(0.66 0.15 258 / 0.72) !important;
}

.dark .raycast-header-control,
.dark .raycast-header-search {
  background: oklch(0.18 0.004 240 / 0.62) !important;
  border-color: oklch(0.34 0.01 240 / 0.74) !important;
  box-shadow:
    0 1px 0 oklch(1 0 0 / 0.06) inset,
    0 12px 26px -22px oklch(0 0 0 / 0.72) !important;
}

.dark .raycast-header-control:hover,
.dark .raycast-header-search:hover {
  background: oklch(0.22 0.004 240 / 0.72) !important;
  border-color: oklch(0.44 0.012 240 / 0.86) !important;
}

.app-shell-header {
  overflow: hidden;
  background: oklch(0.99 0.012 86 / 0.96);
  border-color: oklch(0.78 0.036 82 / 0.95);
  box-shadow:
    0 1px 0 oklch(1 0 0 / 0.82) inset,
    0 1px 2px oklch(0.42 0.06 82 / 0.08);
}

.dark .app-shell-header {
  background: oklch(0.15 0.016 82 / 0.96);
  border-color: oklch(0.42 0.032 82 / 0.95);
  box-shadow:
    0 1px 0 oklch(1 0 0 / 0.06) inset,
    0 1px 2px oklch(0 0 0 / 0.32);
}

.app-shell-search {
  background: oklch(0.982 0.012 86 / 0.82);
  border-color: oklch(0.84 0.028 82 / 0.86);
  box-shadow: 0 1px 0 oklch(1 0 0 / 0.72) inset;
}

.app-shell-search:hover {
  background: oklch(0.99 0.012 86 / 0.94);
  border-color: oklch(0.76 0.045 82 / 0.9);
}

.dark .app-shell-search {
  background: oklch(0.17 0.016 82 / 0.78);
  border-color: oklch(0.34 0.026 82 / 0.86);
  box-shadow: 0 1px 0 oklch(1 0 0 / 0.05) inset;
}

.dark .app-shell-search:hover {
  background: oklch(0.2 0.018 82 / 0.9);
  border-color: oklch(0.46 0.04 82 / 0.92);
}

.heading-display {
  font-family: var(--font-heading);
  line-height: 1.1;
  letter-spacing: -0.01em;
}

.tiptap-editor {
  line-height: 1.75;
}

/* ─── Premium Glassmorphism Cards ─── */
.card-vibrant {
  position: relative;
  z-index: 1;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(15, 23, 42, 0.06);
  box-shadow:
    0 10px 30px -18px rgba(15, 23, 42, 0.1),
    0 1px 0 rgba(255, 255, 255, 0.96) inset;
  isolation: isolate;
  -webkit-backdrop-filter: blur(16px) saturate(1.08);
  backdrop-filter: blur(16px) saturate(1.08);
  transition:
    transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 0.35s cubic-bezier(0.22, 1, 0.36, 1),
    border-color 0.35s cubic-bezier(0.22, 1, 0.36, 1),
    background 0.35s cubic-bezier(0.22, 1, 0.36, 1);
}

.dark .card-vibrant {
  background:
    linear-gradient(
      180deg,
      color-mix(in oklch, var(--prospeo-card) 96%, white 4%),
      var(--prospeo-card)
    ),
    var(--prospeo-card);
  border: 1px solid var(--prospeo-border);
  box-shadow:
    inset 0 1px 0 oklch(1 0 0 / 0.035),
    0 18px 48px -42px oklch(0.02 0 0 / 0.58);
}

.card-vibrant::before {
  position: absolute;
  inset: 0;
  z-index: -1;
  pointer-events: none;
  content: "";
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.18),
    transparent 28%
  );
  opacity: 1;
}

.dark .card-vibrant::before {
  background: linear-gradient(
    180deg,
    color-mix(in oklch, var(--prospeo-active) 4%, transparent),
    transparent 26%
  );
}

.card-vibrant:hover {
  border-color: rgba(15, 23, 42, 0.08);
  box-shadow:
    0 16px 34px -20px rgba(15, 23, 42, 0.15),
    0 1px 0 rgba(255, 255, 255, 1) inset;
  transform: translateY(-2px);
}

.dark .card-vibrant:hover {
  border-color: var(--prospeo-border-strong);
  box-shadow:
    inset 0 1px 0 oklch(1 0 0 / 0.04),
    0 24px 52px -38px oklch(0.02 0 0 / 0.74);
  transform: translateY(-2px);
}

.app-view-surface {
  min-height: 100%;
  background:
    radial-gradient(
      circle at 78% -10%,
      color-mix(in oklch, var(--prospeo-active) 8%, transparent),
      transparent 26%
    ),
    linear-gradient(180deg, var(--prospeo-bg), var(--background));
}

.dark .app-view-surface {
  --background: var(--prospeo-bg);
  --foreground: var(--prospeo-text);
  --card: var(--prospeo-card);
  --card-foreground: var(--prospeo-text);
  --popover: var(--prospeo-shell);
  --popover-foreground: var(--prospeo-text);
  --secondary: var(--prospeo-card-soft);
  --secondary-foreground: var(--prospeo-text);
  --muted: color-mix(
    in oklch,
    var(--prospeo-card-soft) 88%,
    var(--prospeo-bg) 12%
  );
  --muted-foreground: var(--prospeo-muted);
  --accent: color-mix(
    in oklch,
    var(--prospeo-card-soft) 72%,
    var(--prospeo-active) 8%
  );
  --accent-foreground: var(--prospeo-text);
  --border: var(--prospeo-border);
  --input: var(--prospeo-border);
  --ring: color-mix(in oklch, var(--prospeo-active) 42%, white 58%);
  --bg-panel: var(--prospeo-card);
  --text-primary: var(--prospeo-text);
  --text-secondary: var(--prospeo-muted);
  --text-muted: var(--prospeo-faint);
  --border-color: var(--prospeo-border);
}

.app-view-surface > * {
  position: relative;
  z-index: 1;
}

.dark .modal-medical-shell {
  border-color: var(--prospeo-border);
  box-shadow:
    inset 0 1px 0 oklch(1 0 0 / 0.04),
    0 28px 64px -44px oklch(0 0 0 / 0.86);
}

.dark .modal-medical-header {
  background: color-mix(
    in oklch,
    var(--prospeo-card-soft) 84%,
    var(--background) 16%
  );
}

.dark .modal-medical-body {
  background: color-mix(
    in oklch,
    var(--prospeo-card) 92%,
    var(--background) 8%
  );
}

.dark .modal-medical-footer {
  background: color-mix(
    in oklch,
    var(--prospeo-card-soft) 88%,
    var(--background) 12%
  );
  box-shadow: 0 -1px 0
    color-mix(in oklch, var(--prospeo-border) 85%, transparent) inset;
}

/* Metric Glow Effects - Subtle border glows */
.metric-glow-blue {
  box-shadow:
    0 0 0 1px rgba(59, 130, 246, 0.1),
    0 4px 20px -4px rgba(59, 130, 246, 0.08);
}

.metric-glow-orange {
  box-shadow:
    0 0 0 1px rgba(249, 115, 22, 0.1),
    0 4px 20px -4px rgba(249, 115, 22, 0.08);
}

.metric-glow-emerald {
  box-shadow:
    0 0 0 1px rgba(16, 185, 129, 0.1),
    0 4px 20px -4px rgba(16, 185, 129, 0.08);
}

.metric-glow-rose {
  box-shadow:
    0 0 0 1px rgba(244, 63, 94, 0.1),
    0 4px 20px -4px rgba(244, 63, 94, 0.08);
}

.metric-glow-violet {
  box-shadow:
    0 0 0 1px rgba(139, 92, 246, 0.1),
    0 4px 20px -4px rgba(139, 92, 246, 0.08);
}

.metric-glow-cyan {
  box-shadow:
    0 0 0 1px rgba(6, 182, 212, 0.1),
    0 4px 20px -4px rgba(6, 182, 212, 0.08);
}

.metric-glow-amber {
  box-shadow:
    0 0 0 1px rgba(245, 158, 11, 0.1),
    0 4px 20px -4px rgba(245, 158, 11, 0.08);
}

/* ─── Premium Widget Mesh Gradients Base ─── */
/* Base animations defined further down */

/* Button Subtle Style - Reset to professional */
.btn-subtle {
  transition: all 0.2s ease;
}

.btn-subtle:hover {
  box-shadow: 0 4px 12px -2px rgba(0, 0, 0, 0.08);
  transform: translateY(-1px);
}

.btn-subtle:active {
  transform: translateY(0);
}

/* ─── RTL Overrides ─── */
/* Note: dir="rtl" on the SidebarProvider flex container already reverses
   flex item order (sidebar spacer → right, content → left). Do NOT add
   flex-direction: row-reverse as that would double-reverse the layout. */

/* Sidebar inset inherits RTL direction */
html[dir="rtl"] .rtl-shell [data-slot="sidebar-inset"] {
  direction: rtl;
}

/* Flip sidebar trigger chevron */
html[dir="rtl"] .rtl-shell [data-slot="sidebar-trigger"] svg {
  transform: scaleX(-1);
}

/* Sidebar container: position on right side */
html[dir="rtl"] .rtl-shell [data-slot="sidebar-container"][data-side="right"] {
  right: 0;
  left: auto;
}

/* Sidebar gap: undo LTR rotate-180 that shadcn applies for data-side=right */
html[dir="rtl"] .rtl-shell [data-side="right"] [data-slot="sidebar-gap"] {
  transform: none;
}

/* ─── Rainbow border hover effect ─── */

/* Colored left border for priority items */
.priority-bar-high {
  border-left: 3px solid oklch(0.6 0.25 25);
  border-radius: 0 var(--radius) var(--radius) 0;
}
.priority-bar-medium {
  border-left: 3px solid oklch(0.75 0.18 75);
  border-radius: 0 var(--radius) var(--radius) 0;
}
.priority-bar-low {
  border-left: 3px solid oklch(0.65 0.15 250);
  border-radius: 0 var(--radius) var(--radius) 0;
}

html[dir="rtl"] .priority-bar-high,
html[dir="rtl"] .priority-bar-medium,
html[dir="rtl"] .priority-bar-low {
  border-right: 3px solid;
  border-left: none;
  border-radius: var(--radius) 0 0 var(--radius);
}
html[dir="rtl"] .priority-bar-high {
  border-right-color: oklch(0.6 0.25 25);
}
html[dir="rtl"] .priority-bar-medium {
  border-right-color: oklch(0.75 0.18 75);
}
html[dir="rtl"] .priority-bar-low {
  border-right-color: oklch(0.65 0.15 250);
}

/* Alive status dot with pulse */
@keyframes status-breathe {
  0%,
  100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.3);
    opacity: 0.7;
  }
}

.status-dot-alive {
  animation: status-breathe 2s ease-in-out infinite;
}

/* Vibrant sidebar active glow */
.sidebar-active-glow {
  position: relative;
}

.sidebar-active-glow::after {
  position: absolute;
  inset: 0;
  content: "";
  background: linear-gradient(
    135deg,
    oklch(0.75 0.12 35 / 0.08),
    oklch(0.7 0.15 280 / 0.05)
  );
  border-radius: inherit;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.sidebar-active-glow:hover::after,
.sidebar-active-glow[data-active]::after {
  opacity: 1;
}

/* Soft color wash behind metric cards */
.metric-glow-orange {
  box-shadow: 0 12px 40px -12px oklch(0.65 0.22 35 / 0.18);
}
.metric-glow-blue {
  box-shadow: 0 12px 40px -12px oklch(0.55 0.22 260 / 0.18);
}
.metric-glow-emerald {
  box-shadow: 0 12px 40px -12px oklch(0.6 0.2 155 / 0.18);
}
.metric-glow-amber {
  box-shadow: 0 12px 40px -12px oklch(0.65 0.2 75 / 0.18);
}

.dark .metric-glow-orange {
  box-shadow: 0 12px 40px -12px oklch(0.55 0.25 35 / 0.25);
}
.dark .metric-glow-blue {
  box-shadow: 0 12px 40px -12px oklch(0.45 0.25 260 / 0.25);
}
.dark .metric-glow-emerald {
  box-shadow: 0 12px 40px -12px oklch(0.5 0.22 155 / 0.25);
}
.dark .metric-glow-amber {
  box-shadow: 0 12px 40px -12px oklch(0.55 0.22 75 / 0.25);
}

/* Floating action button gradient */
/* Enhanced focus ring with color */
.focus-ring-vibrant:focus-visible {
  outline: none;
  box-shadow:
    0 0 0 2px var(--background),
    0 0 0 4px var(--primary),
    0 0 12px 2px oklch(0.65 0.15 35 / 0.2);
}

/* ─── Premium Widget Mesh Gradients ─── */
@keyframes mesh-spin {
  0% {
    transform: rotate(0deg) scale(1);
  }
  50% {
    transform: rotate(180deg) scale(1.2);
  }
  100% {
    transform: rotate(360deg) scale(1);
  }
}

/* ─── Global App Background Enhancement ─── */
/* Subtle animated background for the entire app */
@keyframes bg-shift {
  0%,
  100% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
}

/* Soft dot grid pattern overlay */
.bg-dot-pattern {
  background-image: radial-gradient(
    circle,
    var(--border) 0.5px,
    transparent 0.5px
  );
  background-size: 24px 24px;
}

/* Elegant scrollbar styling */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: var(--muted-foreground);
  border-radius: 100px;
  opacity: 0.3;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--muted-foreground);
  opacity: 0.5;
}

/* Firefox scrollbar */
* {
  scrollbar-color: var(--muted-foreground) transparent;
  scrollbar-width: thin;
}

/* ─── Smooth Focus States ─── */
/* Enhanced focus ring for interactive elements */
input:focus-visible,
textarea:focus-visible,
select:focus-visible,
button:focus-visible,
[role="button"]:focus-visible {
  outline: none;
  transition: box-shadow 0.2s ease;
}

/* ─── Card Hover Lift Effect ─── */
.card-hover-lift {
  transition:
    transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
    box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.card-hover-lift:hover {
  box-shadow:
    0 4px 20px -8px rgba(0, 0, 0, 0.1),
    0 8px 40px -16px rgba(0, 0, 0, 0.06);
  transform: translateY(-2px);
}

/* ─── Subtle Gradient Text ─── */
/* ─── Glass Surface ─── */
.glass-surface {
  background: rgba(255, 255, 255, 0.7);
  border: 1px solid rgba(255, 255, 255, 0.5);
  -webkit-backdrop-filter: blur(20px) saturate(1.2);
  backdrop-filter: blur(20px) saturate(1.2);
}

.dark .glass-surface {
  background: rgba(0, 0, 0, 0.4);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

/* ─── Animated Shimmer for Loading States ─── */
@keyframes shimmer {
  0% {
    background-position: -200% 0;
  }
  100% {
    background-position: 200% 0;
  }
}

.shimmer-loading {
  background: linear-gradient(
    90deg,
    var(--muted) 25%,
    var(--background) 50%,
    var(--muted) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
}

/* ─── Micro-interaction for badges/pills ─── */
.pill-interactive {
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.pill-interactive:hover {
  box-shadow: 0 2px 8px -2px rgba(0, 0, 0, 0.08);
  transform: scale(1.02);
}

/* ─── Table Row Hover ─── */
.table-row-hover {
  transition:
    background-color 0.2s ease,
    transform 0.15s ease;
}

.table-row-hover:hover {
  background-color: var(--accent);
  transform: scale(1.002);
}

/* ─── Sidebar Enhancement ─── */
.sidebar-item-elegant {
  position: relative;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.sidebar-item-elegant::before {
  position: absolute;
  top: 50%;
  left: 0;
  width: 3px;
  height: 0;
  content: "";
  background: var(--primary);
  border-radius: 0 4px 4px 0;
  transform: translateY(-50%);
  transition: height 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.sidebar-item-elegant[data-active]::before,
.sidebar-item-elegant:hover::before {
  height: 60%;
}

/* ─── Input Enhancement ─── */
.input-elegant {
  border: 1px solid var(--border);
  transition: all 0.2s ease;
}

.input-elegant:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 3px var(--ring);
}

/* ─── Dialog/Modal Backdrop ─── */
.dialog-backdrop-blur {
  -webkit-backdrop-filter: blur(8px);
  backdrop-filter: blur(8px);
}

/* ─── Tab Underline Animation ─── */
.tab-underline-animated {
  position: relative;
}

.tab-underline-animated::after {
  position: absolute;
  bottom: 0;
  left: 50%;
  width: 0;
  height: 2px;
  content: "";
  background: var(--primary);
  border-radius: 2px 2px 0 0;
  transform: translateX(-50%);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.tab-underline-animated[data-state="active"]::after,
.tab-underline-animated:hover::after {
  width: 80%;
}

/* ─── Floating Label Animation ─── */
@keyframes float-label {
  0% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-2px);
  }
  100% {
    transform: translateY(0);
  }
}

.float-gentle {
  animation: float-label 3s ease-in-out infinite;
}

/* ─── Subtle Border Glow on Hover ─── */
.border-glow-hover {
  transition:
    border-color 0.2s ease,
    box-shadow 0.2s ease;
}

.border-glow-hover:hover {
  border-color: var(--primary);
  box-shadow: 0 0 0 1px var(--ring);
}

/* ─── Divider with gradient ─── */
.divider-gradient {
  height: 1px;
  background: linear-gradient(
    90deg,
    transparent 0%,
    var(--border) 20%,
    var(--border) 80%,
    transparent 100%
  );
}

/* ─── Status Indicator Pulse ─── */
@keyframes status-pulse-gentle {
  0%,
  100% {
    box-shadow: 0 0 0 0 currentColor;
  }
  50% {
    box-shadow: 0 0 0 4px transparent;
  }
}

.status-indicator {
  animation: status-pulse-gentle 2s ease-in-out infinite;
}

/* ─── Card Header Accent ─── */
.card-header-accent {
  position: relative;
}

.card-header-accent::after {
  position: absolute;
  right: 16px;
  bottom: 0;
  left: 16px;
  height: 1px;
  content: "";
  background: linear-gradient(
    90deg,
    transparent 0%,
    var(--border) 30%,
    var(--border) 70%,
    transparent 100%
  );
}

/* ─── Tooltip/Popover Enhancement ─── */
.tooltip-elegant {
  box-shadow:
    0 4px 24px -8px rgba(0, 0, 0, 0.12),
    0 0 0 1px rgba(0, 0, 0, 0.04);
  -webkit-backdrop-filter: blur(12px) saturate(1.2);
  backdrop-filter: blur(12px) saturate(1.2);
}

/* ─── Smooth Page Transitions ─── */
.page-enter {
  animation: pageEnter 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

@keyframes pageEnter {
  0% {
    opacity: 0;
    transform: translateY(8px);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ─── Number Counter Animation ─── */
@keyframes countUp {
  0% {
    opacity: 0;
    transform: translateY(10px);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-count-up {
  animation: countUp 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

/* ─── Selection Color ─── */
::selection {
  color: var(--primary-foreground);
  background: var(--primary);
  opacity: 0.3;
}

/* --------------------------------------------------------------------------
   Vetera Luma refresh
   -------------------------------------------------------------------------- */

html,
body,
body * {
  letter-spacing: -0.31px !important;
}

body {
  background:
    radial-gradient(circle at 10% -10%, oklch(0.7 0.16 258 / 0.18), transparent 34rem),
    radial-gradient(circle at 92% 8%, oklch(0.78 0.16 178 / 0.16), transparent 32rem),
    var(--background);
}

#root {
  background: var(--bg-app);
  box-shadow: 0 18px 48px -22px rgba(10, 10, 10, 0.28) !important;
}

/* Match sidebar wrapper bg to root to prevent corner clipping artifact */
.group\/sidebar-wrapper {
  background: var(--bg-app) !important;
}

html:not(.dark) .glass-surface {
  background:
    linear-gradient(180deg, oklch(1 0.006 236 / 0.96), oklch(0.97 0.018 244 / 0.9)),
    var(--card) !important;
  border: 1px solid oklch(0.84 0.04 246) !important;
  box-shadow: var(--shadow-card) !important;
  -webkit-backdrop-filter: none !important;
  backdrop-filter: none !important;
}

html:not(.dark) .card-vibrant::before,
html:not(.dark) .card-vibrant::after {
  display: none !important;
}

html:not(.dark) .card-vibrant:hover,
html:not(.dark) .glass-card:hover,
html:not(.dark) .card-hover-lift:hover {
  border-color: oklch(0.7 0.12 258) !important;
  box-shadow: var(--shadow-lift) !important;
  transform: none !important;
}

.metric-glow-blue,
.metric-glow-orange,
.metric-glow-emerald,
.metric-glow-rose,
.metric-glow-violet,
.metric-glow-cyan,
.metric-glow-amber {
  box-shadow: var(--shadow-card) !important;
}

.priority-bar-high,
.priority-bar-medium,
.priority-bar-low {
  border-left-color: #e5e5e5 !important;
  border-left-width: 1px !important;
  border-radius: var(--radius) !important;
}

.sidebar-active-glow::after,
.sidebar-item-elegant::before,
.tab-underline-animated::after,
.card-header-accent::after,
.divider-gradient {
  background: #e5e5e5 !important;
}

.recharts-cartesian-grid line,
.recharts-polar-grid line {
  stroke: #e5e5e5 !important;
}

.recharts-cartesian-axis-tick text {
  font-family: var(--font-sans) !important;
  fill: #737373 !important;
}


.dark body {
  background: #0a0a0a;
}

.dark .glass-card,
.dark .card-vibrant,
.dark .glass-surface {
  background:
    linear-gradient(
      180deg,
      color-mix(in oklch, var(--prospeo-card) 96%, white 4%),
      var(--prospeo-card)
    ),
    var(--prospeo-card);
  border: 1px solid var(--prospeo-border);
  box-shadow:
    inset 0 1px 0 oklch(1 0 0 / 0.035),
    0 18px 48px -42px oklch(0.02 0 0 / 0.58);
}

.dark .card-vibrant:hover,
.dark .glass-card:hover,
.dark .card-hover-lift:hover {
  border-color: var(--prospeo-border-strong);
  box-shadow:
    inset 0 1px 0 oklch(1 0 0 / 0.04),
    0 24px 52px -38px oklch(0.02 0 0 / 0.74);
}

.dark .recharts-cartesian-grid line,
.dark .recharts-polar-grid line {
  stroke: var(--prospeo-border) !important;
}

.dark .recharts-cartesian-axis-tick text {
  fill: var(--prospeo-muted) !important;
}

/* --------------------------------------------------------------------------
   Dashboard atelier finish
   -------------------------------------------------------------------------- */

.dashboard-luxe-card {
  position: relative;
  background:
    radial-gradient(
      circle at 6% 0%,
      var(--dashboard-aura-blue),
      transparent 30%
    ),
    linear-gradient(180deg, var(--dashboard-panel), var(--card)) !important;
  border: 0 !important;
  box-shadow:
    0 1px 0 oklch(1 0 0 / 0.48) inset,
    0 12px 30px -26px oklch(0.18 0.03 240 / 0.34) !important;
}

.dashboard-luxe-card::before {
  position: absolute;
  inset: 0;
  z-index: 1;
  padding: 1px;
  pointer-events: none;
  content: "";
  background: linear-gradient(
    135deg,
    var(--dashboard-border-accent),
    var(--dashboard-border-soft) 42%,
    oklch(0.76 0.08 166 / 0.18)
  );
  border-radius: inherit;
  -webkit-mask:
    linear-gradient(oklch(1 0 0) 0 0) content-box,
    linear-gradient(oklch(1 0 0) 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
}

.dashboard-luxe-card > * {
  position: relative;
  z-index: 2;
}

.dashboard-soft-panel {
  background: linear-gradient(
    180deg,
    oklch(1 0 0 / 0.62),
    oklch(0.98 0.006 232 / 0.48)
  );
  border: 1px solid var(--dashboard-border-soft);
  box-shadow: 0 1px 0 oklch(1 0 0 / 0.42) inset;
}

.dark .dashboard-soft-panel {
  background: linear-gradient(
    180deg,
    oklch(0.22 0.025 236 / 0.72),
    oklch(0.16 0.022 236 / 0.62)
  );
  box-shadow: 0 1px 0 oklch(1 0 0 / 0.06) inset;
}

.dashboard-chart-frame {
  padding: 14px 10px 6px;
  background: oklch(0.985 0.006 230 / 0.52);
  border: 1px solid var(--dashboard-border-soft);
  border-radius: 22px;
}

.dark .dashboard-chart-frame {
  background: oklch(0.18 0.02 236 / 0.58);
}

.dashboard-luxe-card .recharts-cartesian-grid line {
  stroke: oklch(0.82 0.02 235 / 0.62) !important;
  stroke-dasharray: 3 8;
}

.dark .dashboard-luxe-card .recharts-cartesian-grid line {
  stroke: oklch(0.36 0.028 238 / 0.62) !important;
}

.dashboard-stage {
  position: relative;
  padding-top: 0.5rem;
}

.dashboard-stage::before {
  position: absolute;
  inset: -4rem 0 auto;
  z-index: -1;
  height: 22rem;
  pointer-events: none;
  content: "";
  background:
    radial-gradient(circle at 14% 4%, oklch(0.86 0.055 74 / 0.42), transparent 22rem),
    radial-gradient(circle at 82% 0%, oklch(0.84 0.045 188 / 0.34), transparent 24rem),
    linear-gradient(180deg, oklch(0.965 0.024 88 / 0.64), transparent);
}

.dashboard-stage::after {
  position: absolute;
  inset: 3.5rem 1rem auto auto;
  z-index: -1;
  width: min(38vw, 28rem);
  height: min(38vw, 28rem);
  pointer-events: none;
  content: "";
  background:
    linear-gradient(90deg, oklch(0.42 0.045 78 / 0.12) 1px, transparent 1px),
    linear-gradient(oklch(0.42 0.045 78 / 0.1) 1px, transparent 1px);
  background-size: 22px 22px;
  border-radius: 999px;
  mask-image: radial-gradient(circle, black, transparent 68%);
  transform: rotate(-8deg);
}

.dashboard-command-panel {
  position: relative;
  padding: 0.9rem 0 0.45rem;
  overflow: visible;
  background: transparent;
  border: 0;
  box-shadow: none;
}

.dashboard-command-panel h1 {
  font-family: "Instrument Serif", Georgia, serif;
  font-weight: 500 !important;
  letter-spacing: -0.07em !important;
}

.dashboard-command-panel h1::after {
  display: inline-block;
  width: 0.18em;
  height: 0.18em;
  margin-left: 0.12em;
  vertical-align: 0.03em;
  content: "";
  background: oklch(0.72 0.08 76);
  border-radius: 999px;
}

.dark .dashboard-command-panel {
  background: transparent;
  box-shadow: none;
}

.dashboard-eyebrow {
  width: fit-content;
  padding: 0;
  color: oklch(0.42 0.055 78);
  font-weight: 700;
  font-size: 0.68rem;
  letter-spacing: 0.14em !important;
  text-transform: uppercase;
  background: transparent;
  border: 0;
  border-radius: 0;
}

.dark .dashboard-eyebrow {
  color: oklch(0.76 0.08 82);
  background: transparent;
  border-color: transparent;
}

.dashboard-date-pill {
  max-width: 16rem;
  padding: 0.72rem 0.9rem;
  color: oklch(0.43 0.035 78);
  background: oklch(0.965 0.022 88 / 0.7);
  border: 0;
  border-radius: 999px;
}

.dark .dashboard-date-pill {
  color: oklch(0.78 0.05 84);
  background: oklch(0.22 0.018 76 / 0.64);
  border-color: transparent;
}

.dashboard-kpi-card,
.dashboard-chart-card,
.dashboard-table-card {
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 12% 0%, oklch(0.9 0.045 72 / 0.26), transparent 15rem),
    linear-gradient(180deg, oklch(0.99 0.012 86 / 0.98), oklch(0.965 0.018 86 / 0.94)) !important;
  border: 1px solid oklch(0.86 0.024 82 / 0.88) !important;
  border-radius: 28px !important;
  box-shadow:
    0 1px 0 oklch(1 0 0 / 0.72) inset,
    0 18px 42px -36px oklch(0.38 0.07 82 / 0.32) !important;
  transition:
    border-color 180ms ease,
    box-shadow 180ms ease,
    transform 180ms ease;
}

.dashboard-kpi-card::before,
.dashboard-chart-card::before,
.dashboard-table-card::before {
  position: absolute;
  inset: 0;
  pointer-events: none;
  content: "";
  background: linear-gradient(135deg, oklch(1 0 0 / 0.72), transparent 28%, transparent 72%, oklch(0.68 0.05 78 / 0.12));
  border-radius: inherit;
}

.dashboard-kpi-card:hover,
.dashboard-chart-card:hover,
.dashboard-table-card:hover {
  border-color: oklch(0.78 0.052 78 / 0.9) !important;
  box-shadow:
    0 1px 0 oklch(1 0 0 / 0.76) inset,
    0 26px 58px -42px oklch(0.38 0.08 82 / 0.42) !important;
  transform: translateY(-1px);
}

.dashboard-kpi-card:nth-child(2) {
  background:
    radial-gradient(circle at 12% 0%, oklch(0.84 0.055 188 / 0.24), transparent 16rem),
    linear-gradient(180deg, oklch(0.99 0.012 86 / 0.98), oklch(0.95 0.02 178 / 0.8)) !important;
}

.dashboard-kpi-card:nth-child(3) {
  background:
    radial-gradient(circle at 12% 0%, oklch(0.88 0.06 112 / 0.22), transparent 16rem),
    linear-gradient(180deg, oklch(0.99 0.012 86 / 0.98), oklch(0.95 0.022 116 / 0.78)) !important;
}

.dashboard-kpi-card:nth-child(4) {
  background:
    radial-gradient(circle at 12% 0%, oklch(0.86 0.055 34 / 0.2), transparent 16rem),
    linear-gradient(180deg, oklch(0.99 0.012 86 / 0.98), oklch(0.955 0.02 44 / 0.78)) !important;
}

.dark .dashboard-kpi-card,
.dark .dashboard-chart-card,
.dark .dashboard-table-card {
  background:
    radial-gradient(circle at 12% 0%, oklch(0.62 0.08 78 / 0.16), transparent 16rem),
    linear-gradient(180deg, oklch(0.18 0.018 82 / 0.94), oklch(0.12 0.014 92 / 0.96)) !important;
  border-color: oklch(0.34 0.026 82 / 0.9) !important;
  box-shadow:
    0 1px 0 oklch(1 0 0 / 0.055) inset,
    0 18px 48px -36px oklch(0.04 0.02 250 / 0.78) !important;
}

.dashboard-kpi-card::after,
.dashboard-chart-card::after,
.dashboard-table-card::after {
  position: absolute;
  inset: 0;
  pointer-events: none;
  content: "";
  background-image: radial-gradient(oklch(0.45 0.045 82 / 0.08) 1px, transparent 1px);
  background-size: 18px 18px;
  mask-image: linear-gradient(180deg, black, transparent 58%);
}

.dashboard-kpi-card > *,
.dashboard-chart-card > *,
.dashboard-table-card > * {
  position: relative;
  z-index: 1;
}

.dashboard-kpi-label {
  color: oklch(0.42 0.036 78);
  font-weight: 650;
  letter-spacing: 0.03em !important;
}

.dashboard-kpi-value {
  color: oklch(0.2 0.035 78);
  font-family: "Instrument Serif", Georgia, serif;
  font-size: clamp(2.15rem, 3vw, 3rem) !important;
  font-weight: 500 !important;
  letter-spacing: -0.08em !important;
}

.dark .dashboard-kpi-label {
  color: oklch(0.72 0.045 82);
}

.dark .dashboard-kpi-value {
  color: oklch(0.96 0.012 246);
}

.dashboard-kpi-badge {
  background: oklch(0.95 0.032 86 / 0.76) !important;
  border-color: oklch(0.78 0.052 78 / 0.48) !important;
  color: oklch(0.38 0.07 78) !important;
}

.dashboard-chart-canvas {
  padding: 0.75rem 0.75rem 0.25rem;
  background: oklch(0.982 0.012 86 / 0.62);
  border: 1px solid oklch(0.86 0.024 82 / 0.62);
  border-radius: 20px;
}

.dark .dashboard-chart-canvas {
  background: oklch(0.16 0.014 92 / 0.62);
  border-color: oklch(0.32 0.024 82 / 0.72);
}

.dashboard-table-frame {
  border-color: oklch(0.86 0.024 82 / 0.72) !important;
  background: oklch(0.988 0.012 86 / 0.72);
}

.dark .dashboard-table-frame {
  border-color: oklch(0.32 0.024 82 / 0.72) !important;
  background: oklch(0.14 0.014 92 / 0.72);
}

.dashboard-ai-fab {
  background: linear-gradient(135deg, oklch(0.84 0.07 82), oklch(0.78 0.055 188));
  box-shadow: 0 20px 42px -22px oklch(0.58 0.08 82 / 0.62);
}

/* --------------------------------------------------------------------------
   Prospeo-style dashboard surface
   -------------------------------------------------------------------------- */

.prospeo-dashboard {
  position: relative;
  min-height: 100%;
  color: var(--prospeo-text);
  background-color: var(--prospeo-bg);
}

.prospeo-dashboard.prospeo-dark,
.dark .prospeo-dashboard {
  background-color: var(--prospeo-bg);
}

.prospeo-shell {
  background: var(--prospeo-shell);
  border: 1px solid var(--prospeo-border);
  box-shadow: var(--prospeo-shadow);
}

/* --------------------------------------------------------------------------
   Clinical modal polish
   -------------------------------------------------------------------------- */
.modal-medical-shell {
  border: 1px solid color-mix(in oklch, var(--border) 92%, transparent);
  box-shadow:
    0 1px 0 color-mix(in oklch, white 76%, transparent) inset,
    0 24px 54px -34px color-mix(in oklch, black 34%, transparent);
}

.modal-medical-header {
  background: color-mix(in oklch, var(--background) 86%, var(--muted) 14%);
}

.modal-medical-body {
  background: color-mix(in oklch, var(--background) 96%, var(--muted) 4%);
}

.modal-medical-footer {
  background: color-mix(in oklch, var(--background) 88%, var(--muted) 12%);
  box-shadow: 0 -1px 0 color-mix(in oklch, var(--border) 85%, transparent) inset;
}

.modal-medical-footer .modal-medical-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: flex-end;
}

.modal-hero-shell {
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(
      120% 140% at 0% 0%,
      color-mix(in oklch, #6fd3ff 30%, white) 0%,
      transparent 42%
    ),
    radial-gradient(
      110% 140% at 100% 0%,
      color-mix(in oklch, #ffd58a 34%, white) 0%,
      transparent 48%
    ),
    radial-gradient(
      90% 120% at 50% 100%,
      color-mix(in oklch, #ff8d76 26%, white) 0%,
      transparent 52%
    ),
    linear-gradient(
      180deg,
      color-mix(in oklch, white 94%, var(--muted) 6%) 0%,
      color-mix(in oklch, white 98%, var(--muted) 2%) 100%
    );
  border-bottom: 1px solid color-mix(in oklch, var(--border) 88%, transparent);
}

.modal-hero-frame {
  border: 1px solid color-mix(in oklch, white 50%, var(--border) 50%);
  box-shadow:
    0 1px 0 color-mix(in oklch, white 85%, transparent) inset,
    0 34px 70px -46px color-mix(in oklch, black 28%, transparent);
  backdrop-filter: blur(20px) saturate(1.08);
}

.modal-hero-shell::before {
  position: absolute;
  inset: 0;
  pointer-events: none;
  content: "";
  background: linear-gradient(
    135deg,
    color-mix(in oklch, white 30%, transparent) 0%,
    transparent 35%,
    color-mix(in oklch, white 34%, transparent) 100%
  );
}

.modal-hero-badge {
  display: inline-flex;
  gap: 0.55rem;
  align-items: center;
  background: color-mix(in oklch, white 84%, transparent);
  border: 1px solid color-mix(in oklch, white 72%, var(--border) 28%);
  border-radius: 999px;
  box-shadow:
    0 1px 0 color-mix(in oklch, white 90%, transparent) inset,
    0 18px 40px -34px color-mix(in oklch, black 22%, transparent);
  backdrop-filter: blur(10px);
}

.modal-hero-stat {
  background: color-mix(in oklch, white 78%, transparent);
  border: 1px solid color-mix(in oklch, white 70%, var(--border) 30%);
  border-radius: 1.15rem;
  box-shadow: 0 16px 36px -30px color-mix(in oklch, black 20%, transparent);
  backdrop-filter: blur(12px);
}

.modal-hero-footer {
  background: linear-gradient(
    180deg,
    color-mix(in oklch, white 92%, transparent),
    color-mix(in oklch, white 98%, var(--muted) 2%)
  );
  box-shadow: 0 1px 0 color-mix(in oklch, white 80%, transparent) inset;
}

.modal-hero-action {
  align-items: flex-start;
  justify-content: flex-start;
  min-height: 154px;
  padding: 1.15rem 1.1rem;
  text-align: left;
  white-space: normal;
  border-radius: 1.35rem;
  box-shadow:
    0 1px 0 color-mix(in oklch, white 75%, transparent) inset,
    0 18px 36px -30px color-mix(in oklch, black 20%, transparent);
}

.modal-hero-action > span,
.modal-hero-action [class*="grid"] {
  min-width: 0;
}

.modal-hero-action [class*="grid"] > span:last-child {
  overflow-wrap: anywhere;
}

.modal-hero-action[data-variant="primary"] {
  background: linear-gradient(
    180deg,
    color-mix(in oklch, var(--primary) 92%, white 8%) 0%,
    color-mix(in oklch, var(--primary) 100%, black 0%) 100%
  );
}

.modal-hero-action[data-variant="secondary"] {
  background: linear-gradient(
    180deg,
    color-mix(in oklch, white 94%, var(--muted) 6%) 0%,
    color-mix(in oklch, white 99%, var(--muted) 1%) 100%
  );
  border-color: color-mix(in oklch, var(--border) 88%, white 12%);
}

.dark .modal-medical-shell {
  box-shadow:
    0 1px 0 color-mix(in oklch, white 10%, transparent) inset,
    0 30px 70px -42px color-mix(in oklch, black 70%, transparent);
}

.dark .modal-hero-frame {
  border-color: color-mix(in oklch, white 10%, var(--border) 90%);
}

.dark .modal-hero-shell {
  background:
    radial-gradient(
      120% 140% at 0% 0%,
      color-mix(in oklch, #63c8ff 22%, transparent) 0%,
      transparent 46%
    ),
    radial-gradient(
      110% 140% at 100% 0%,
      color-mix(in oklch, #ffc96e 18%, transparent) 0%,
      transparent 50%
    ),
    radial-gradient(
      90% 120% at 50% 100%,
      color-mix(in oklch, #ff8a72 18%, transparent) 0%,
      transparent 54%
    ),
    linear-gradient(
      180deg,
      color-mix(in oklch, var(--background) 90%, var(--muted) 10%) 0%,
      color-mix(in oklch, var(--background) 96%, var(--muted) 4%) 100%
    );
}

.dark .modal-hero-badge,
.dark .modal-hero-stat {
  background: color-mix(in oklch, var(--background) 74%, white 6%);
  border-color: color-mix(in oklch, white 10%, var(--border) 90%);
}

.dark .modal-hero-footer {
  background: linear-gradient(
    180deg,
    color-mix(in oklch, var(--background) 86%, transparent),
    color-mix(in oklch, var(--background) 94%, var(--muted) 6%)
  );
}