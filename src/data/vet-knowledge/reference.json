    "formulas": {
        "fluidotherapie": {
            "maintenance": {
                "formule": "30 × poids(kg) + 70 mL/jour",
                "alternative": "50-60 mL/kg/jour",
                "exemple": "Chien 10kg: 30×10+70 = 370 mL/jour"
            },
            "choc_crystalloides": {
                "chien": "80-90 mL/kg sur 1h (en bolus de 20 mL/kg)",
                "chat": "40-60 mL/kg sur 1h (en bolus de 10-15 mL/kg)"
            },
            "deshydratation": {
                "formule": "Poids(kg) × % déshydratation × 10 = Volume (mL) à corriger",
                "exemple": "Chien 20kg déshydraté 8%: 20 × 8 × 10 = 1600 mL",
                "evaluation": {
                    "5%": "Légère - pli de peau légèrement persistant",
                    "6-8%": "Modérée - pli persistant, muqueuses sèches",
                    "10-12%": "Sévère - yeux enfoncés, choc",
                    ">12%": "Critique - moribond"
                }
            },
            "deficit_potassium": {
                "formule": "Supplément selon kaliémie",
                "tableau": {
                    "<2.0": "80 mEq/L",
                    "2.0-2.5": "60 mEq/L",
                    "2.5-3.0": "40 mEq/L",
                    "3.0-3.5": "28 mEq/L"
                },
                "vitesse_max": "0.5 mEq/kg/h"
            }
        },
        "transfusion": {
            "volume_sang": {
                "formule": "Volume(mL) = Poids(kg) × 90 × (Ht cible - Ht patient) / Ht donneur",
                "regle_simple": "2 mL/kg de sang total augmente Ht de 1%"
            },
            "vitesse": {
                "normale": "5-10 mL/kg/h",
                "urgence": "Jusqu'à 22 mL/kg/h",
                "debut": "0.25 mL/kg pendant 15-30 min (surveillance réaction)"
            }
        },
        "nutrition": {
            "RER": {
                "formule": "70 × Poids(kg)^0.75 kcal/jour",
                "simplifiee": "30 × Poids(kg) + 70 kcal/jour (pour 2-45kg)"
            },
            "MER": {
                "chien_repos": "RER × 1.4",
                "chien_actif": "RER × 1.6-2.0",
                "chat": "RER × 1.2-1.4",
                "croissance": "RER × 2-3",
                "lactation": "RER × 2-4"
            }
        },
        "anesthesie": {
            "volume_courant": "10-15 mL/kg",
            "frequence_respiratoire": "8-20/min",
            "volume_minute": "150-250 mL/kg/min",
            "debit_O2": "50-100 mL/kg/min (circuit ouvert)",
            "isoflurane_MAC": {
                "chien": "1.3%",
                "chat": "1.6%"
            },
            "sevoflurane_MAC": {
                "chien": "2.4%",
                "chat": "2.6%"
            }
        },
        "cardiologie": {
            "VHS": {
                "chien": {
                    "normal": "<10.5",
                    "cardiomegalie": ">10.5"
                },
                "chat": {
                    "normal": "<8.0",
