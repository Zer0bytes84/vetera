    "vaccinations": {
        "chien": {
            "core": {
                "CHPPi": {
                    "nom_complet": "Maladie de Carré, Hépatite de Rubarth, Parvovirose, Parainfluenza",
                    "protocole": {
                        "primovaccination": [
                            "6-8 semaines",
                            "10-12 semaines",
                            "14-16 semaines"
                        ],
                        "rappel": "12 mois après primovaccination",
                        "rappels_ulterieurs": "Tous les 3 ans (CHPPi) selon guidelines WSAVA"
                    }
                },
                "Rage": {
                    "obligatoire": "Déplacement international, zones endémiques",
                    "protocole": {
                        "primovaccination": "À partir de 12 semaines",
                        "rappel": "Annuel ou tous les 3 ans selon législation et vaccin"
                    }
                }
            },
            "non_core": {
                "Leptospirose": {
                    "recommande": "Chiens à risque (eau stagnante, rats)",
                    "protocole": {
                        "primovaccination": [
                            "8-9 semaines",
                            "12 semaines"
                        ],
                        "rappel": "Annuel (protection courte durée)"
                    }
                },
                "Bordetella": {
                    "recommande": "Collectivités, pensions, expositions",
                    "protocole": {
                        "intranasal": "Dose unique, protection rapide 72h",
                        "injectable": "2 doses à 2-4 semaines d'intervalle"
                    }
                },
                "Leishmaniose": {
                    "recommande": "Zones endémiques (sud Europe, Afrique Nord)",
                    "protocole": {
                        "primovaccination": [
                            "6 mois",
                            "3 semaines après",
                            "3 semaines après"
                        ],
                        "rappel": "Annuel"
                    }
                },
                "Lyme": {
                    "recommande": "Zones endémiques tiques Ixodes",
                    "protocole": {
                        "primovaccination": [
                            "12 semaines",
                            "4 semaines après"
                        ],
                        "rappel": "Annuel avant saison des tiques"
                    }
                }
            }
        },
        "chat": {
