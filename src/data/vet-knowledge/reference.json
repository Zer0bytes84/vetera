                }
            },
            "frequence_cardiaque": {
                "chien_petit": "100-140 bpm",
                "chien_moyen": "80-120 bpm",
                "chien_grand": "60-100 bpm",
                "chat": "140-220 bpm"
            }
        },
        "surface_corporelle": {
            "formule": "SC(m²) = 10 × Poids(kg)^(2/3) / 10000",
            "simplifiee_chien": "SC = 0.1 × Poids^0.67"
        }
