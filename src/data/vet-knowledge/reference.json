                        "primovaccination": [
                            "8-9 semaines",
                            "12 semaines"
                        ],
                        "rappel": "12 mois",
                        "rappels_ulterieurs": "Tous les 3 ans (Typhus), annuel à tous les 3 ans (Coryza selon risque)"
                    }
                },
                "Rage": {
                    "obligatoire": "Déplacement international",
                    "protocole": {
                        "primovaccination": "À partir de 12 semaines",
                        "rappel": "Selon législation"
                    }
                }
            },
            "non_core": {
                "FeLV": {
                    "recommande": "Chats sortant, contacts positifs",
                    "protocole": {
